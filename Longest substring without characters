int func(string s) {
    int hash[256];
    for (int i = 0; i < 256; i++) hash[i] = -1;

    int l = 0;
    int maxLen = 0;

    for (int r = 0; r < s.size(); r++) {
        if (hash[s[r]] != -1) {
            if (hash[s[r]] >= l) {
                l = hash[s[r]] + 1;
            }
        }

        hash[s[r]] = r;

        int len = r - l + 1;
        maxLen = max(len, maxLen);
    }

    return maxLen;
}
