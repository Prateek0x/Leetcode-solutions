class Solution {
public:
    int sumOddLengthSubarrays(vector<int>& arr) {
        vector<int> arr1;
        int n = arr.size();
        int total = 0;
        for(int i = 0; i<n; i++){
            int totalSubarrays = (i + 1) * (n - i);
            int oddCount = (totalSubarrays + 1) / 2;

            total += arr[i] * oddCount;
        }
        return total;
    }
};
