class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        int start = 0;
        int end = 0;
        double sum = 0;
         double maxAverage = INT_MIN;
        while(end < nums.size()){
        while(end - start + 1 <= k) {
             sum += nums[end];
            end++;
        }
         maxAverage = max(maxAverage , sum/k);
        sum -= nums[start];
        start++;
        }
         return maxAverage;
    }
    
};
