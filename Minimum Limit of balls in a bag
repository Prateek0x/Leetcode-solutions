class Solution {
public:
    bool function(int x, int maxOperations, vector<int>& nums){
        long long count = 0;

        for (int num: nums){
            count += ceil((double)num/x) - 1;
        }

        return count <= maxOperations;
    }

    int minimumSize(vector<int>& nums, int maxOperations) {
        int low = 1, high = pow(10,9);

        while (low <= high){
            int mid = (low+high)/2;

            if (function(mid,maxOperations,nums)){
                high = mid - 1;
            } else {
                low = mid + 1;
            }
        }

        return low;
    }
};
