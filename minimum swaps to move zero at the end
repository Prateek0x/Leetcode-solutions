class Solution {
public:
    int minimumSwaps(vector<int>& nums) {
        int n = nums.size();
      int zero = 0;
        for(int i = 0; i<n; i++){
           if(nums[i] == 0)
               zero++;    
           }
           int ans = 0;
            for(int i = n - zero; i < n; i++){
                if(nums[i] != 0){
                    ans++;
                }
            }
            return ans;
    }
    };©leetcode
