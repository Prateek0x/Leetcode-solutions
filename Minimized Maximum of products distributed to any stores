long long countStores(vector<int>& quantities, int mid)
{
    long long stores = 0;

    for(int q : quantities)
    {
        stores += ceil((double)q / mid);
    }

    return stores;
}

class Solution {
public:
    int minimizedMaximum(int n, vector<int>& quantities) {
    int low = 1;
    int high = *max_element(quantities.begin(), quantities.end());

    while(low <= high)
    {
        int mid = (low + high) / 2;

        long long stores = countStores(quantities, mid);

        if(stores > n)
        {
            low = mid + 1;
        }
        else
        {
            high = mid - 1;
        }
    }

    return low;
    }
};
