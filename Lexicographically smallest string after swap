class Solution {
public:
    string getSmallestString(string s) {
        for(int i=0; i<s.size()-1; i++){
            if(s[i]>s[i+1]){
                int a = s[i] -'0';
                int b = s[i+1]-'0';
                if(a%2==0 and b%2!=0)continue;
                if(a%2!=0 and b%2==0)continue;
                char temp = s[i];
                s[i]= s[i+1];
                s[i+1]= temp;
                break;
            }
        }
        return s;
    }
};
