class Solution {
public:
    vector<int> findWordsContaining(vector<string>& words, char x) {
        
        vector<int> ans;

        // Traverse all words
        for (int i = 0; i < words.size(); i++) {

            // Check if character exists
            if (words[i].find(x) != string::npos) {
                ans.push_back(i);
            }
        }

        return ans;
    }
};
