class Solution {
public:
    bool threeConsecutiveOdds(vector<int>& arr) {
        short int i;        // to traverse array in loop
        if (arr.size() < 3) // size less than 3
            return false;

        for (i = 0; i < arr.size() - 2; i++) {
            // checking three consecutive indexes
            if ((arr[i] & 1) && (arr[i + 1] & 1) && (arr[i + 2] & 1))
                return true;
        }
        return false;
    }
};
