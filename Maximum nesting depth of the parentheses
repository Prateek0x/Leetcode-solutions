class Solution {
public:
    int maxDepth(string s) {
       int ob = 0; //openbracket
       int result = 0;
       for(char & ch:s){
        if(ch == '('){
            ob++;
        }
        else if(ch == ')'){
            ob--;
        }
        result = max(result,ob);
       }
       return result;
    }
};
