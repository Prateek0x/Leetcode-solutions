class Solution {
public:
    int uniqueXorTriplets(vector<int>& nums) {
        int n = nums.size();

        // Edge cases
        if (n == 1 || n == 2)
            return n;

        // Convert all bits right of the MSB into 1s
        n |= (n >> 1);
        n |= (n >> 2);
        n |= (n >> 4);
        n |= (n >> 8);
        n |= (n >> 16);

        // Next power of 2
        return n + 1;
    }
};
